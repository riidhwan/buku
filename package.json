{
  "name": "buku",
  "version": "0.2.0",
  "description": "Android-first Ionic Angular app.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:debug": "ng build --configuration development",
    "build:release": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "test:watch": "ng test",
    "lint": "eslint . --max-warnings=0",
    "lint:styles": "stylelint \"src/**/*.scss\" --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "cap:sync:android": "cap sync android",
    "android:sync:debug": "pnpm build:debug && cap sync android",
    "android:sync:release": "pnpm build:release && cap sync android",
    "android:build:debug": "pnpm android:sync:debug && cd android && ./gradlew assembleDebug",
    "android:build:release": "pnpm android:sync:release && cd android && ./gradlew assembleRelease",
    "release:validate": "node .github/scripts/validate-release.mjs",
    "android:install:debug": "pnpm android:sync:debug && cd android && ./gradlew installDebug",
    "prepare": "husky >/dev/null 2>&1 || true"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/platform-browser": "20.3.25",
    "@angular/router": "20.3.25",
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/preferences": "8.0.1",
    "@ionic/angular": "^8.0.0",
    "@mozilla/readability": "^0.6.0",
    "ionicons": "^7.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.30",
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/schematics": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/cli": "20.3.30",
    "@angular/compiler-cli": "20.3.25",
    "@angular/language-service": "20.3.25",
    "@capacitor/cli": "8.4.1",
    "@ionic/angular-toolkit": "^12.0.0",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.2.1",
    "eslint-plugin-prefer-arrow": "1.2.2",
    "husky": "^9.1.7",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "typescript": "~5.9.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.7",
      "esbuild": "0.28.1",
      "http-proxy-middleware": "3.0.7",
      "uuid": "11.1.1"
    }
  },
  "lint-staged": {
    "*.{ts,html,scss,json,md}": "prettier --write",
    "*.ts": "eslint --max-warnings=0",
    "*.scss": "stylelint --max-warnings=0"
  }
}
