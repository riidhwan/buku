{
  "name": "buku",
  "version": "0.8.0",
  "description": "Android-first Ionic Angular app.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:debug": "ng build --configuration development",
    "build:release": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "test:watch": "ng test",
    "lint": "eslint . --max-warnings=0",
    "lint:styles": "stylelint \"src/**/*.scss\" --max-warnings=0",
    "architecture:changed": "node scripts/architecture-report.mjs --changed",
    "architecture:check": "node scripts/architecture-report.mjs --all --fail-on-hard",
    "architecture:staged": "node scripts/architecture-report.mjs --staged",
    "test-obligation:changed": "node scripts/test-obligation.mjs --changed",
    "test-obligation:check": "node scripts/test-obligation.mjs --all",
    "test-obligation:staged": "node scripts/test-obligation.mjs --staged",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "cap:sync:android": "cap sync android",
    "android:sync:debug": "pnpm build:debug && cap sync android",
    "android:sync:release": "pnpm build:release && cap sync android",
    "android:build:debug": "pnpm android:sync:debug && cd android && ./gradlew assembleDebug",
    "android:build:release": "pnpm android:sync:release && cd android && ./gradlew assembleRelease",
    "release:validate": "node .github/scripts/validate-release.mjs",
    "android:install:debug": "pnpm android:sync:debug && cd android && ./gradlew installDebug",
    "prepare": "husky >/dev/null 2>&1 || true"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.5",
    "@angular/common": "22.0.5",
    "@angular/compiler": "22.0.5",
    "@angular/core": "22.0.5",
    "@angular/forms": "22.0.5",
    "@angular/platform-browser": "22.0.5",
    "@angular/router": "22.0.5",
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/preferences": "8.0.1",
    "@ionic/angular": "^8.8.13",
    "@mozilla/readability": "^0.6.0",
    "ionicons": "^8.0.13",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "22.0.6",
    "@angular-eslint/builder": "22.0.0",
    "@angular-eslint/eslint-plugin": "22.0.0",
    "@angular-eslint/eslint-plugin-template": "22.0.0",
    "@angular-eslint/schematics": "22.0.0",
    "@angular-eslint/template-parser": "22.0.0",
    "@angular/cli": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@angular/language-service": "22.0.6",
    "@capacitor/cli": "8.4.1",
    "@ionic/angular-toolkit": "^12.0.0",
    "@types/jasmine": "~6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "angular-eslint": "22.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-boundaries": "^7.0.2",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^63.0.12",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "husky": "^9.1.7",
    "jasmine-core": "~6.3.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript-eslint": "^8.63.0",
    "typescript": "~7.0.2"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.7",
      "esbuild": "0.28.1",
      "http-proxy-middleware": "3.0.7",
      "uuid": "11.1.1",
      "webpack-dev-server": "5.2.5"
    }
  },
  "lint-staged": {
    "*.{ts,html,scss,json,md}": "prettier --write",
    "*.ts": [
      "eslint --max-warnings=0",
      "node scripts/architecture-report.mjs",
      "node scripts/test-obligation.mjs"
    ],
    "*.scss": "stylelint --max-warnings=0"
  }
}
